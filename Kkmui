local movesetBackup = nil
local espelhamentoAtivo = false

-- Função para copiar moveset de um jogador
local function copiarMoveset(jogador)
    if not jogador then return false end
    
    local statzDoAlvo = jogador:FindFirstChild("statz")
    if not statzDoAlvo then return false end
    
    local movesetAlvo = statzDoAlvo:FindFirstChild("movesetsaving")
    if not movesetAlvo then return false end
    
    -- Fazer backup do moveset atual
    local meuStatz = player:FindFirstChild("statz")
    if meuStatz then
        local meuMoveset = meuStatz:FindFirstChild("movesetsaving")
        if meuMoveset then
            movesetBackup = meuMoveset:Clone()
        end
    end
    
    -- Copiar moveset do alvo
    local novoMoveset = movesetAlvo:Clone()
    novoMoveset.Parent = meuStatz
    
    -- Matar o personagem para aplicar as mudanças
    local char = player.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.Health = 0
    end
    
    return true
end

-- Função para restaurar moveset original
local function restaurarMoveset()
    if not movesetBackup then return false end
    
    local meuStatz = player:FindFirstChild("statz")
    if meuStatz then
        local atual = meuStatz:FindFirstChild("movesetsaving")
        if atual then atual:Destroy() end
        movesetBackup:Clone().Parent = meuStatz
    end
    
    local char = player.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.Health = 0
    end
    
    return true
end

