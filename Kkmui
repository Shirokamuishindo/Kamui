-- Carregar configurações salvas
local function carregarConfiguracoes()
    pcall(function()
        local configStore = player:FindFirstChild("KamuiConfig")
        if configStore then
            for chave, _ in pairs(configuracoes) do
                local intVal = configStore:FindFirstChild(chave)
                if intVal and intVal:IsA("BoolValue") then
                    configuracoes[chave] = intVal.Value
                end
            end
        end
    end)
end

-- Aplicar configurações carregadas
local function aplicarConfiguracoes()
    if configuracoes.autoFarm then
        pcall(function()
            if not (rawget(_G, "autoFarmAtivo") or false) then
                -- Iniciar auto farm
            end
        end)
    end
    if configuracoes.autoAccept then iniciarAutoAccept() end
    if configuracoes.antiStun then iniciarAntiStun() end
    if configuracoes.autoRespawn then iniciarAutoRespawn() end
    if configuracoes.visualChams then ligarVisualChams() end
end

-- Carregar ao iniciar
carregarConfiguracoes()
task.wait(1)
aplicarConfiguracoes()

