local raioAimbot = 300

-- Função para encontrar o jogador mais próximo do centro da tela
local function encontrarAlvoNaMira()
    local cameraCF = Camera.CFrame
    local cameraPos = cameraCF.Position
    local cameraLook = cameraCF.LookVector
    
    local melhorAlvo = nil
    local melhorAngulo = math.rad(15) -- 15 graus de tolerância
    local melhorDistancia = raioAimbot
    
    for _, jogador in ipairs(Players:GetPlayers()) do
        if jogador ~= player and jogador.Character then
            local char = jogador.Character
            local hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head")
            if hrp then
                local alvoPos = hrp.Position
                local direcaoAlvo = (alvoPos - cameraPos).Unit
                local angulo = math.acos(math.clamp(cameraLook:Dot(direcaoAlvo), -1, 1))
                local distancia = (cameraPos - alvoPos).Magnitude
                
                if angulo < melhorAngulo and distancia < melhorDistancia then
                    melhorAngulo = angulo
                    melhorDistancia = distancia
                    melhorAlvo = jogador
                end
            end
        end
    end
    
    return melhorAlvo
end

-- Função para mirar no alvo
local function mirarNoAlvo(alvo)
    if not alvo or not alvo.Character then return end
    
    local char = alvo.Character
    local hrp = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Head")
    if not hrp then return end
    
    -- Atualiza a câmera para olhar para o alvo
    local cameraPos = Camera.CFrame.Position
    local targetPos = hrp.Position
    local novaCF = CFrame.new(cameraPos, targetPos)
    Camera.CFrame = novaCF
    
    -- Se o personagem não estiver voando, vira o corpo também
    if not (rawget(_G, "voando") or false) then
        local meuChar = player.Character
        if meuChar and meuChar:FindFirstChild("HumanoidRootPart") then
            meuChar.HumanoidRootPart.CFrame = CFrame.new(meuChar.HumanoidRootPart.Position, targetPos)
        end
    end
end

-- Função para atacar o alvo
local function atacarAlvo()
    if not alvoAtual or not alvoAtual.Character then return end
    
    local charAlvo = alvoAtual.Character
    local hrp = charAlvo:FindFirstChild("HumanoidRootPart") or charAlvo:FindFirstChild("Head")
    if not hrp then return end
    
    -- Dispara clique do mouse
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
    task.wait(0.03)
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
    
    -- Usa skills básicas
    for _, key in pairs({Enum.KeyCode.Z, Enum.KeyCode.X}) do
        VirtualInputManager:SendKeyEvent(true, key, false, game)
        task.wait(0.05)
        VirtualInputManager:SendKeyEvent(false, key, false, game)
        task.wait(0.05)
    end
end

local function iniciarAimbot()
    if aimbotAtivo then return end
    aimbotAtivo = true
    
    aimbotTask = task.spawn(function()
        while aimbotAtivo do
            pcall(function()
                -- Encontra o melhor alvo
                if not alvoAtual or not alvoAtual.Character then
                    alvoAtual = encontrarAlvoNaMira()
                end
                
                -- Se tem alvo, mira e ataca
                if alvoAtual and alvoAtual.Character then
                    mirarNoAlvo(alvoAtual)
                    atacarAlvo()
                else
                    -- Se perdeu o alvo, procura novamente
                    alvoAtual = encontrarAlvoNaMira()
                end
            end)
            task.wait(0.05)
        end
    end)
    
    -- Notificação
    pcall(function()
        local gui = player:FindFirstChild("PlayerGui")
        if gui then
            local msg = Instance.new("TextLabel", gui)
            msg.Size = UDim2.new(0, 250, 0, 35)
            msg.Position = UDim2.new(0.5, -125, 0.75, 0)
            msg.Text = "🎯 AIMBOT ATIVADO (Tecla 2) 🎯"
            msg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            msg.BackgroundTransparency = 0.3
            msg.TextColor3 = Color3.fromRGB(255, 100, 100)
            msg.Font = Enum.Font.GothamBold
            msg.TextSize = 14
            Instance.new("UICorner", msg).CornerRadius = UDim.new(0, 8)
            task.wait(2)
            msg:Destroy()
        end
    end)
end

local function pararAimbot()
    aimbotAtivo = false
    if aimbotTask then
        task.cancel(aimbotTask)
        aimbotTask = nil
    end
    alvoAtual = nil
end

