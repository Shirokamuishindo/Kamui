-- 2. ANTI-STUN (Evita ser atordoado/derrubado)
-- =========================
local antiStunAtivo = false
local antiStunTask = nil
local estadoOriginal = {}

local function aplicarAntiStun()
    local char = player.Character
    if not char then return end
    
    local hum = char:FindFirstChild("Humanoid")
    if not hum then return end
    
    -- Salva estado original se não existir
    if not estadoOriginal.hum then
        estadoOriginal.hum = hum
        estadoOriginal.platformStand = hum.PlatformStand
        estadoOriginal.sit = hum.Sit
    end
    
    -- Corrige estados de stun
    if hum.PlatformStand and not rawget(_G, "voando") then
        hum.PlatformStand = false
    end
    
    -- Corrige se estiver sentado acidentalmente
    if hum.Sit then
        hum.Sit = false
    end
    
    -- Mantém velocidade se não estiver voando
    if not (rawget(_G, "voando") or false) and hum.WalkSpeed < 16 and hum.WalkSpeed > 0 then
        hum.WalkSpeed = 16
    end
    
    -- Remove efeitos de ragdoll/stun
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BodyVelocity") or part:IsA("BodyGyro") then
            if part.Name ~= "KamuiFlyBV" then
                part:Destroy()
            end
        end
    end
end

local function iniciarAntiStun()
    if antiStunAtivo then return end
    antiStunAtivo = true
    
    antiStunTask = RunService.Heartbeat:Connect(function()
        if antiStunAtivo then
            pcall(aplicarAntiStun)
        end
    end)
    
    notificar("🛡️ Anti-Stun ativado!", "Você não será mais atordoado", 2)
end

local function pararAntiStun()
    antiStunAtivo = false
    if antiStunTask then
        antiStunTask:Disconnect()
        antiStunTask = nil
    end
    notificar("⚠️ Anti-Stun desativado", "", 1.5)
end

