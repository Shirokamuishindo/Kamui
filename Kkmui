local function verificarERenascer()
    local char = player.Character
    if not char then
        -- Personagem não existe (morto)
        if not respawnTask then
            respawnTask = task.spawn(function()
                while autoRespawnAtivo and not player.Character do
                    pcall(function()
                        -- Tenta renascer pelo evento padrão
                        local respawnEvent = ReplicatedStorage:FindFirstChild("Respawn")
                        if respawnEvent and respawnEvent:IsA("RemoteEvent") then
                            respawnEvent:FireServer()
                        end
                        
                        -- Tenta via BindToClose
                        player:LoadCharacter()
                        
                        -- Alternativa: tecla R
                        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.R, false, game)
                        task.wait(0.1)
                        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.R, false, game)
                    end)
                    task.wait(2)
                end
                respawnTask = nil
            end)
        end
    elseif respawnTask then
        task.cancel(respawnTask)
        respawnTask = nil
    end
end

