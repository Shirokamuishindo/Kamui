    abaBtn.ZIndex = 10
    Instance.new("UICorner", abaBtn).CornerRadius = UDim.new(0, 6)
    
    local elementos = {}
    
    local function mostrar()
        for _, child in ipairs(content:GetChildren()) do
            if not child:IsA("UIListLayout") then
                child:Destroy()
            end
        end
        for _, elem in ipairs(elementos) do
            elem.Parent = content
        end
    end
    
    abaBtn.MouseButton1Click:Connect(mostrar)
    
    return {
        adicionarBotao = function(titulo, desc, cb)
            table.insert(elementos, criarBotao(titulo, desc, cb))
        end,
        adicionarToggle = function(titulo, desc, val, cb)
            table.insert(elementos, criarToggle(titulo, desc, val, cb))
        end
    }
end

