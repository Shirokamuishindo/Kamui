    desc.Position = UDim2.new(0, 0, 0, 42)
    desc.Text = descricao
    desc.TextColor3 = Color3.fromRGB(160, 160, 180)
    desc.BackgroundTransparency = 1
    desc.Font = Enum.Font.Gotham
    desc.TextSize = 12
    desc.TextWrapped = true
    
    local ativo = valorInicial
    local function atualizarUI()
        btn.Text = titulo .. " [" .. (ativo and "✓" or "✗") .. "]"
        btn.BackgroundColor3 = ativo and Color3.fromRGB(50, 70, 50) or Color3.fromRGB(35, 35, 45)
