-- Função para reproduzir macro
local function reproduzirMacro()
    if macroReproduzindo then return end
    if #acoesGravadas == 0 then
        pcall(function()
            local gui = player:FindFirstChild("PlayerGui")
            if gui then
                local msg = Instance.new("TextLabel", gui)
                msg.Size = UDim2.new(0, 250, 0, 35)
                msg.Position = UDim2.new(0.5, -125, 0.75, 0)
                msg.Text = "⚠️ Nenhuma macro gravada! Grave primeiro com M"
                msg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                msg.BackgroundTransparency = 0.3
                msg.TextColor3 = Color3.fromRGB(255, 200, 0)
                msg.Font = Enum.Font.GothamBold
                msg.TextSize = 12
                Instance.new("UICorner", msg).CornerRadius = UDim.new(0, 8)
                task.wait(2)
                msg:Destroy()
            end
        end)
        return
    end
    
    macroReproduzindo = true
    
    macroTask = task.spawn(function()
        local tempoInicial = tick()
        local index = 1
        
        while macroReproduzindo and index <= #acoesGravadas do
            local acao = acoesGravadas[index]
            local tempoAlvo = acao.tempo
            
            -- Aguarda até o momento certo
            while tick() - tempoInicial < tempoAlvo and macroReproduzindo do
                task.wait(0.01)
            end
            
            if not macroReproduzindo then break end
            
            -- Executa a ação
            if acao.tipo == "key" then
                VirtualInputManager:SendKeyEvent(acao.down, acao.key, false, game)
                if acao.down then
                    task.wait(0.05)
                    VirtualInputManager:SendKeyEvent(false, acao.key, false, game)
                end
            elseif acao.tipo == "click" then
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, acao.down, game, 1)
            end
            
            index = index + 1
        end
        
        macroReproduzindo = false
        
        pcall(function()
            local gui = player:FindFirstChild("PlayerGui")
            if gui then
                local msg = Instance.new("TextLabel", gui)
                msg.Size = UDim2.new(0, 250, 0, 35)
                msg.Position = UDim2.new(0.5, -125, 0.75, 0)
                msg.Text = "✅ Macro finalizada!"
                msg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
