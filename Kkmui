-- Método 1: Varredura no Garbage Collector
local function limparCooldownsMemoria()
    local success, gc = pcall(getgc, true)
    if not success then return end
    
    for _, obj in pairs(gc) do
        if type(obj) == "function" then
            local success, info = pcall(debug.getinfo, obj)
            if success and info then
                local nomeFunc = string.lower(info.name or info.what or "")
                -- Palavras-chave de cooldown
                if string.find(nomeFunc, "cooldown") or string.find(nomeFunc, "cd") or 
                   string.find(nomeFunc, "timer") or string.find(nomeFunc, "wait") or
                   string.find(nomeFunc, "delay") or string.find(nomeFunc, "reset") then
                    
                    local upvalues = debug.getupvalues(obj)
                    for i, valor in pairs(upvalues) do
                        if type(valor) == "number" and valor > 0 and valor < 999 then
                            pcall(debug.setupvalue, obj, i, 0)
                        end
                        if type(valor) == "boolean" and valor == true then
                            pcall(debug.setupvalue, obj, i, false)
                        end
                    end
                end
            end
        end
    end
end

-- Método 2: Hook no require para interceptar módulos
local oldRequire = require
local modulesHooked = {}
require = function(module)
    local result = oldRequire(module)
    if type(result) == "table" and not modulesHooked[module] then
        modulesHooked[module] = true
        for k, v in pairs(result) do
            if type(v) == "function" then
                local kLow = string.lower(k)
                if string.find(kLow, "cooldown") or string.find(kLow, "cd") or string.find(kLow, "wait") then
                    rawset(result, k, function(...) 
                        return nil 
                    end)
                end
            end
        end
    end
    return result
end

-- Método 3: Hook no RemoteEvent/RemoteFunction (se existir)
pcall(function()
    local remoteEvents = ReplicatedStorage:FindFirstChild("Remotes") or ReplicatedStorage
    if remoteEvents then
        for _, rem in pairs(remoteEvents:GetChildren()) do
            if rem:IsA("RemoteEvent") or rem:IsA("RemoteFunction") then
                if not rem._hooked then
                    rem._hooked = true
                    if rem.OnClientEvent then
                        local oldEvent = rem.OnClientEvent
                        rem.OnClientEvent = function(...)
                            -- Filtra chamadas de cooldown
                            return oldEvent(...)
                        end
                    end
                end
            end
        end
    end
end)

