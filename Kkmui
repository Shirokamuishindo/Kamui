-- Movimentação durante o voo
RunService.RenderStepped:Connect(function()
    if not voando then return end
    
    local char = player.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp or not bodyVelocityFly then return end
    
    -- Direção do movimento
    local movimento = Vector3.new(0, 0, 0)
    
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
        movimento = movimento + hrp.CFrame.LookVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then
        movimento = movimento - hrp.CFrame.LookVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then
        movimento = movimento + hrp.CFrame.RightVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then
        movimento = movimento - hrp.CFrame.RightVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
        movimento = movimento + Vector3.new(0, 50, 0)
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
        movimento = movimento - Vector3.new(0, 50, 0)
    end
    
    if movimento.Magnitude > 0 then
        bodyVelocityFly.Velocity = movimento.Unit * velocidadeVoo
    else
        bodyVelocityFly.Velocity = Vector3.new(0, 0, 0)
    end
    
    -- Manter noclip ativo
    for _, parte in pairs(char:GetDescendants()) do
        if parte:IsA("BasePart") then
            parte.CanCollide = false
        end
    end
end)

