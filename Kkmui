-- =========================
local voando = false
local bodyVelocityFly = nil
local velocidadeVoo = 85

local function iniciarVoo()
    voando = true
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- BodyVelocity para controle de voo
    bodyVelocityFly = Instance.new("BodyVelocity")
    bodyVelocityFly.MaxForce = Vector3.new(1e6, 1e6, 1e6)
    bodyVelocityFly.Velocity = Vector3.new(0, 0, 0)
    bodyVelocityFly.Parent = hrp
    
    -- Noclip: desabilita colisão em todas as partes do personagem
    for _, parte in pairs(char:GetDescendants()) do
        if parte:IsA("BasePart") then
            parte.CanCollide = false
        end
    end
    
    -- Desabilita gravidade e colisão do humanoid
    local hum = char:FindFirstChild("Humanoid")
    if hum then
        hum.PlatformStand = true
    end
    
    -- Notificação visual
    pcall(function()
        local gui = player:FindFirstChild("PlayerGui")
        if gui then
            local flyMsg = Instance.new("TextLabel", gui)
            flyMsg.Size = UDim2.new(0, 180, 0, 30)
            flyMsg.Position = UDim2.new(0.5, -90, 0.85, 0)
            flyMsg.Text = "✈️ MODO VOO ATIVADO ✈️"
            flyMsg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            flyMsg.BackgroundTransparency = 0.3
            flyMsg.TextColor3 = Color3.fromRGB(100, 200, 255)
            flyMsg.Font = Enum.Font.GothamBold
            flyMsg.TextSize = 14
            Instance.new("UICorner", flyMsg).CornerRadius = UDim.new(0, 8)
            task.wait(1.5)
            flyMsg:Destroy()
        end
    end)
end

local function pararVoo()
    voando = false
    if bodyVelocityFly then
        bodyVelocityFly:Destroy()
        bodyVelocityFly = nil
    end
    
    local char = player.Character
    if char then
        -- Reabilita colisão
        for _, parte in pairs(char:GetDescendants()) do
            if parte:IsA("BasePart") then
                parte.CanCollide = true
            end
        end
        
        -- Reabilita gravidade
        local hum = char:FindFirstChild("Humanoid")
        if hum then
            hum.PlatformStand = false
        end
    end
    
    pcall(function()
        local gui = player:FindFirstChild("PlayerGui")
        if gui then
            local flyMsg = Instance.new("TextLabel", gui)
            flyMsg.Size = UDim2.new(0, 180, 0, 30)
            flyMsg.Position = UDim2.new(0.5, -90, 0.85, 0)
            flyMsg.Text = "🛑 MODO VOO DESATIVADO 🛑"
            flyMsg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            flyMsg.BackgroundTransparency = 0.3
            flyMsg.TextColor3 = Color3.fromRGB(255, 100, 100)
            flyMsg.Font = Enum.Font.GothamBold
            flyMsg.TextSize = 14
            Instance.new("UICorner", flyMsg).CornerRadius = UDim.new(0, 8)
            task.wait(1.5)
            flyMsg:Destroy()
        end
    end)
end

