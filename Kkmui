local function formatarVida(hp)
    hp = math.max(0, math.floor(hp or 0))
    if hp >= 1000 then
        return math.floor(hp / 1000) .. "k"
    end
    return tostring(hp)
end

local function criarESP(jogador)
    if espObjetos[jogador] then return end
    local char = jogador.Character
    if not char then return end
    local parte = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
    if not parte then return end
    
    local bill = Instance.new("BillboardGui")
    bill.Name = "KamuiESP"
    bill.Adornee = parte
    bill.Size = UDim2.new(0, 140, 0, 36)
    bill.AlwaysOnTop = true
    bill.StudsOffset = Vector3.new(0, 2.5, 0)
    bill.Parent = gui
    
    local label = Instance.new("TextLabel", bill)
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = jogador.Team == player.Team and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 50, 50)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 12
    label.TextStrokeTransparency = 0.4
    label.TextYAlignment = Enum.TextYAlignment.Center
    label.TextXAlignment = Enum.TextXAlignment.Center
    
    espObjetos[jogador] = {gui = bill, label = label}
end

local function removerESP(jogador)
    local data = espObjetos[jogador]
    if data and data.gui then
        data.gui:Destroy()
    end
    espObjetos[jogador] = nil
end

local function atualizarESP()
    for _, jogador in ipairs(Players:GetPlayers()) do
        if jogador ~= player then
            if espAtivo and jogador.Character and jogador.Character:FindFirstChild("Humanoid") then
                criarESP(jogador)
                local data = espObjetos[jogador]
                if data and data.label then
                    local hum = jogador.Character.Humanoid
                    data.label.Text = jogador.Name .. "\n❤️ " .. formatarVida(hum.Health)
                end
            else
                removerESP(jogador)
            end
        end
    end
end

local function ligarESP()
    espAtivo = true
    atualizarESP()
end

local function desligarESP()
    espAtivo = false
    for jogador in pairs(espObjetos) do
        removerESP(jogador)
    end
end

