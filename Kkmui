local function adicionarBotoesConfig()
    local guiPrincipal = player:FindFirstChild("PlayerGui"):FindFirstChild("KamuiXHub")
    if not guiPrincipal then return end
    
    local framePrincipal = guiPrincipal:FindFirstChild("Frame")
    if not framePrincipal then return end
    
    -- Procura o content frame
    local contentFrame = nil
    for _, child in pairs(framePrincipal:GetChildren()) do
        if child:IsA("ScrollingFrame") and child.Position.X.Scale > 0.2 then
            contentFrame = child
            break
        end
    end
    
    if not contentFrame then return end
    
    -- Criar seção Configurações
    local secao = Instance.new("Frame", contentFrame)
    secao.Size = UDim2.new(0.95, 0, 0, 320)
    secao.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    secao.BackgroundTransparency = 0.5
    secao.ZIndex = 10
    Instance.new("UICorner", secao).CornerRadius = UDim.new(0, 8)
    
    local titulo = Instance.new("TextLabel", secao)
    titulo.Size = UDim2.new(1, 0, 0, 30)
    titulo.Text = "⚙️ CONFIGURAÇÕES DO HUB"
    titulo.TextColor3 = Color3.fromRGB(255, 200, 100)
    titulo.BackgroundTransparency = 1
    titulo.Font = Enum.Font.GothamBold
    titulo.TextSize = 14
    titulo.ZIndex = 11
    
    local layout = Instance.new("UIListLayout", secao)
    layout.Padding = UDim.new(0, 5)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    
    -- Função para criar toggle dentro da seção
    local function criarToggleSecao(nome, desc, chave, callback)
        local holder = Instance.new("Frame", secao)
        holder.Size = UDim2.new(0.95, 0, 0, 50)
        holder.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
        holder.BackgroundTransparency = 0.4
        holder.ZIndex = 11
        Instance.new("UICorner", holder).CornerRadius = UDim.new(0, 6)
        
        local btn = Instance.new("TextButton", holder)
        btn.Size = UDim2.new(0.5, 0, 0, 35)
        btn.Position = UDim2.new(0.03, 0, 0.07, 0)
        btn.Text = nome
        btn.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
        btn.TextColor3 = Color3.fromRGB(220, 220, 220)
        btn.Font = Enum.Font.GothamBold
        btn.TextSize = 13
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
        
        local statusLabel = Instance.new("TextLabel", holder)
        statusLabel.Size = UDim2.new(0.3, 0, 0, 25)
        statusLabel.Position = UDim2.new(0.65, 0, 0.2, 0)
        statusLabel.Text = configuracoes[chave] and "✅ ATIVADO" or "❌ DESATIVADO"
        statusLabel.TextColor3 = configuracoes[chave] and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 100, 100)
        statusLabel.BackgroundTransparency = 1
        statusLabel.Font = Enum.Font.GothamBold
        statusLabel.TextSize = 12
        statusLabel.TextXAlignment = Enum.TextXAlignment.Right
        
        local descLabel = Instance.new("TextLabel", holder)
        descLabel.Size = UDim2.new(0.95, 0, 0, 15)
        descLabel.Position = UDim2.new(0.03, 0, 0.65, 0)
        descLabel.Text = desc
        descLabel.TextColor3 = Color3.fromRGB(150, 150, 170)
        descLabel.BackgroundTransparency = 1
        descLabel.Font = Enum.Font.Gotham
        descLabel.TextSize = 11
        descLabel.TextXAlignment = Enum.TextXAlignment.Left
        
        btn.MouseButton1Click:Connect(function()
            configuracoes[chave] = not configuracoes[chave]
            statusLabel.Text = configuracoes[chave] and "✅ ATIVADO" or "❌ DESATIVADO"
            statusLabel.TextColor3 = configuracoes[chave] and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 100, 100)
            pcall(callback, configuracoes[chave])
            salvarConfiguracoes()
        end)
    end
    
    -- Adicionar toggles
    criarToggleSecao("🌾 Auto Farm", "Farm automático de inimigos próximos", "autoFarm", function(val)
        if val then
            if not (rawget(_G, "autoFarmAtivo") or false) then
                -- Iniciar auto farm (função da Parte 3)
                pcall(function()
                    if iniciarAutoFarm then iniciarAutoFarm() end
                end)
            end
        else
            if rawget(_G, "autoFarmAtivo") then
                pcall(function()
                    if pararAutoFarm then pararAutoFarm() end
                end)
            end
        end
    end)
    
    criarToggleSecao("📦 Auto Coleta", "Pega itens do chão automaticamente", "autoColeta", function(val)
        if val then
            pcall(function()
                if iniciarAutoColeta then iniciarAutoColeta() end
            end)
        else
            pcall(function()
                if pararAutoColeta then pararAutoColeta() end
            end)
        end
    end)
    
    criarToggleSecao("✅ Auto Accept", "Aceita missões, eventos e convites automaticamente", "autoAccept", function(val)
        if val then
            iniciarAutoAccept()
        else
            pararAutoAccept()
        end
    end)
    
    criarToggleSecao("🛡️ Anti-Stun", "Evita ser atordoado ou derrubado", "antiStun", function(val)
        if val then
            iniciarAntiStun()
        else
            pararAntiStun()
        end
    end)
    
    criarToggleSecao("🔄 Auto Respawn", "Renasce automaticamente ao morrer", "autoRespawn", function(val)
        if val then
            iniciarAutoRespawn()
        else
            pararAutoRespawn()
        end
    end)
    
    criarToggleSecao("👁️ Visual Chams", "Destaca jogadores com cores", "visualChams", function(val)
        if val then
            ligarVisualChams()
        else
            desligarVisualChams()
        end
    end)
end

