-- Hook para gravar ações (teclas e cliques) durante a gravação
local function hookInputGravacao()
    -- Gravar teclas
    local keyConn = UserInputService.InputBegan:Connect(function(input, processed)
        if macroGravando and not processed then
            if input.KeyCode ~= Enum.KeyCode.M then -- Evita gravar a tecla de parar
                local tempo = tick() - inicioGravacao
                table.insert(acoesGravadas, {
                    tipo = "key",
                    key = input.KeyCode,
                    down = true,
                    tempo = tempo
                })
            end
        end
    end)
    
    -- Gravar cliques do mouse
    local clickConn = UserInputService.InputBegan:Connect(function(input, processed)
        if macroGravando and not processed then
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                local tempo = tick() - inicioGravacao
                table.insert(acoesGravadas, {
                    tipo = "click",
                    down = true,
                    tempo = tempo
                })
            end
        end
    end)
    
    -- Limpar conexões quando parar de gravar
    task.spawn(function()
        while macroGravando do
            task.wait(0.5)
        end
        keyConn:Disconnect()
        clickConn:Disconnect()
    end)
end

-- Tecla M para controlar macro
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.M then
        if macroGravando then
            pararGravacaoMacro()
        elseif macroReproduzindo then
            pararMacro()
        else
            iniciarGravacaoMacro()
            hookInputGravacao()
        end
    end
end)

