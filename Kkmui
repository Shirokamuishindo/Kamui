-- Função para detectar e aceitar missões
local function aceitarMissoes()
    -- Procura por GUI de missão
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return end
    
    -- Verifica se tem alguma janela de missão aberta
    for _, gui in pairs(playerGui:GetChildren()) do
        if gui:IsA("Frame") or gui:IsA("ScreenGui") then
            -- Procura por botões de "Accept", "Start", "Join", "Enter"
            local botoes = {}
            local function buscarBotoes(obj)
                for _, child in pairs(obj:GetChildren()) do
                    if child:IsA("TextButton") then
                        local texto = string.lower(child.Text or "")
                        if string.find(texto, "accept") or 
                           string.find(texto, "start") or 
                           string.find(texto, "join") or 
                           string.find(texto, "enter") or
                           string.find(texto, "ok") or
                           string.find(texto, "yes") then
                            table.insert(botoes, child)
                        end
                    end
                    buscarBotoes(child)
                end
            end
            buscarBotoes(gui)
            
            -- Clica nos botões encontrados
            for _, botao in pairs(botoes) do
                pcall(function()
                    botao:Click()
                    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
                    task.wait(0.05)
                    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
                end)
            end
        end
    end
    
    -- Verifica notificações pop-up
    local notifications = playerGui:FindFirstChild("Notifications")
    if notifications then
        for _, notif in pairs(notifications:GetChildren()) do
            if notif:IsA("Frame") and notif:FindFirstChild("AcceptButton") then
                pcall(function()
                    notif.AcceptButton:Click()
                end)
            end
        end
    end
end

-- Função para aceitar convites de party/clã
local function aceitarConvites()
    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then return end
    
    -- Procura por convites (interface de party)
    for _, gui in pairs(playerGui:GetChildren()) do
        if gui.Name == "InviteGui" or string.find(string.lower(gui.Name), "invite") then
            for _, btn in pairs(gui:GetDescendants()) do
                if btn:IsA("TextButton") and string.find(string.lower(btn.Text or ""), "accept") then
                    pcall(btn.Click, btn)
                end
            end
        end
    end
end

-- Função para interagir com NPCs próximos automaticamente
local function interagirComNPCs()
    local char = player.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local raioInteracao = 40
    local npcs = Workspace:FindFirstChild("NPCs") or Workspace
    
    for _, obj in pairs(npcs:GetChildren()) do
        if obj:FindFirstChild("Humanoid") and not obj:IsA("Player") then
            local parte = obj:FindFirstChild("Head") or obj:FindFirstChild("HumanoidRootPart")
            if parte then
                local dist = (hrp.Position - parte.Position).Magnitude
                if dist < raioInteracao then
                    -- Tenta interagir com o NPC (tecla E)
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                    task.wait(0.1)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
                    task.wait(0.5)
                    
                    -- Tenta clicar no NPC
                    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
                    task.wait(0.05)
                    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
                    task.wait(0.5)
                end
            end
        end
    end
end

